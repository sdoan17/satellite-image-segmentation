# Path to the PyTorch checkpoint loaded by the FastAPI inference service.
# The default is models/pytorch_model.pth relative to the repository root.
SATSEG_MODEL_PATH=models/pytorch_model.pth

# Comma-separated frontend origins allowed to call /health and /predict.
# Use the deployed Vercel URL in production and localhost during local development.
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-project.vercel.app
